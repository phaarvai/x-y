{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./migrate": "./src/migrate.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "migrate": "tsx ./src/migrate.ts up",
    "migrate:status": "tsx ./src/migrate.ts status",
    "migrate:rollback": "tsx ./src/migrate.ts rollback",
    "migrate:repeatable": "tsx ./src/migrate.ts repeatable",
    "seed": "tsx ./src/seed.ts",
    "seed:mvp": "tsx ./src/seed-mvp.ts"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}
