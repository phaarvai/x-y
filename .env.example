# Shared / root environment template — copy to `.env` (never commit secrets)

# App
NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/xiy
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000
DB_POOL_CONNECT_MS=10000

# Auth
SESSION_SECRET=replace-with-long-random-string

# API server
PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
ENABLE_COMPRESSION=true
ENABLE_SWAGGER=true
LOG_LEVEL=info

# Storage (XFY-086)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_BASE_URL=/api/files
UPLOAD_MAX_BYTES=10485760
SIGNED_URL_TTL_SECONDS=900
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=uploads
# GCS_BUCKET=
# GCS_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=

# Feature flags
FF_FILE_UPLOADS=true
FF_AUDIT_API=true

# Observability
METRICS_ENABLED=false
# SENTRY_DSN=

# Seed admin (local/dev only)
SEED_ADMIN_EMAIL=admin@explorerfactory.local
SEED_ADMIN_PASSWORD=ChangeMeAdmin!17

# Payments (existing)
# PAYMENT_WEBHOOK_SECRET=
